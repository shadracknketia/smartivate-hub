---
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-container">
		<div class="footer-grid">
			<!-- Column 1: Brand -->
			<div class="footer-col">
				<h2 class="footer-logo">Smartivate Hub</h2>
				<p class="footer-mission">Helping you learn technology the practical way through guides, tutorials, and real-world projects.</p>
			</div>

			<!-- Column 2: Explore -->
			<div class="footer-col">
				<h3>Explore</h3>
				<ul class="footer-links">
					<li><a href="/about">About</a></li>
					<li><a href="/tools">Tools</a></li>
					<li><a href="/courses">Courses</a></li>
					<li><a href="/resources">Resources</a></li>
				</ul>
			</div>

			<!-- Column 3: Learn -->
			<div class="footer-col">
				<h3>Learn</h3>
				<ul class="footer-links">
					<li><a href="/category/Guides">Guides</a></li>
					<li><a href="/category/Tutorials">Tutorials</a></li>
					<li><a href="/category/Projects">Projects</a></li>
				</ul>
			</div>

			<!-- Column 4: Consultation -->
			<div class="footer-col">
				<h3>Consultation</h3>
				<p>Need 1-on-1 help? Chat with me directly:</p>
				<div class="chat-buttons">
					<a href="https://wa.me/YOUR_PHONE_NUMBER" class="chat-btn wa">WhatsApp</a>
					<a href="https://t.me/YOUR_TELEGRAM_USERNAME" class="chat-btn tg">Telegram</a>
				</div>
			</div>
		</div>
		
		<div class="footer-bottom">
			<p>&copy; {today.getFullYear()} Smartivate Hub.</p>
			<a href="/privacy">Privacy Policy</a>
		</div>
	</div>
</footer>

<style>
	.site-footer { 
		background: #0f172a; 
		color: #f8fafc; 
		padding: 4rem 1rem 2rem 1rem; 
		margin-top: 5rem;
		text-align: left; /* Fixes the centering issue */
	}
	.footer-container { max-width: 1200px; margin: 0 auto; }
	
	.footer-grid { 
		display: grid; 
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); 
		gap: 2rem; 
		margin-bottom: 3rem;
	}
	
	.footer-logo { color: #fff; margin-bottom: 1rem; font-size: 1.5rem; }
	.footer-mission { color: #94a3b8; line-height: 1.6; font-size: 0.9rem; }
	
	.footer-col h3 { color: #fff; font-size: 1.1rem; margin-bottom: 1.2rem; border-bottom: 2px solid #4f46e5; display: inline-block; padding-bottom: 4px;}
	
	/* FORCE REMOVE BULLETS */
	.footer-links { 
		list-style: none !important; 
		padding: 0 !important; 
		margin: 0 !important;
	}
	.footer-links li { margin-bottom: 0.8rem; list-style-type: none !important; }
	.footer-links li a { color: #94a3b8; text-decoration: none; }
	.footer-links li a:hover { color: #4f46e5; }
	
	/* Chat Buttons */
	.chat-buttons { display: flex; flex-direction: column; gap: 0.8rem; margin-top: 1rem; }
	.chat-btn { 
		padding: 0.6rem 1rem; 
		border-radius: 6px; 
		text-decoration: none; 
		font-weight: bold; 
		text-align: center; 
		color: white !important;
		font-size: 0.9rem;
	}
	.wa { background: #25d366; } /* WhatsApp Green */
	.tg { background: #0088cc; } /* Telegram Blue */
	
	.footer-bottom { 
		border-top: 1px solid #1e293b; 
		padding-top: 2rem; 
		display: flex; 
		justify-content: space-between; 
		font-size: 0.8rem; 
		color: #64748b; 
	}
    .footer-bottom a { color: #64748b; text-decoration: none; }

	@media (max-width: 768px) {
		.footer-grid { grid-template-columns: 1fr; }
	}
</style>