---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
		<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<a href="/">Home</a>
			
			<!-- Learn Dropdown -->
			<div class="dropdown">
				<button class="dropbtn">Learn ▾</button>
				<div class="dropdown-content">
					<a href="/category/Guides">Guides</a>
					<a href="/category/Tutorials">Tutorials</a>
					<a href="/category/Projects">Projects</a>
				</div>
			</div>

			<a href="/tools">Tools</a>
			<a href="/courses">Courses</a>
			<a href="/resources">Resources</a>
			<a href="/about">About</a>
			<a href="/contact">Contact</a>
		</div>
	</nav>
</header>

<style>
	header {
	margin: 0;
	padding: 0;
	background: white;
	box-shadow: 0 2px 8px rgba(var(--black), 5%);
		}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		
		/* --- THE FIX IS HERE --- */
		max-width: 1200px;    /* Matches your homepage width */
		margin: 0 auto;       /* Centers the navbar */
		padding: 1rem 2rem;   /* Adds breathing room on the sides */
	}

	/* Ensure the logo/brand doesn't have extra margin pushing it */
	nav h2 {
		margin: 0;
		font-size: 1.5rem;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	/* Mobile Fix: Ensure it still looks good on small screens */
	@media (max-width: 720px) {
		nav {
			padding: 1rem;
		}
		.internal-links {
			display: none; /* Usually, you'd implement a mobile menu here later */
		}
	}

	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}

	/* Standard Links */
	.internal-links a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	.internal-links a.active {
		border-bottom-color: var(--accent);
	}

	/* Dropdown Container */
	.dropdown {
		display: inline-block;
		position: relative;
	}

	/* Dropdown Button */
	.dropbtn {
		background: none;
		border: none;
		font-size: 1em;
		font-weight: 500;
		padding: 1em 0.5em;
		cursor: pointer;
		color: var(--black);
	}

	/* Dropdown Content (Hidden by Default) */
	.dropdown-content {
		display: none;
		position: absolute;
		background-color: white;
		min-width: 160px;
		box-shadow: 0px 8px 16px rgba(0,0,0,0.1);
		z-index: 10;
		border-radius: 8px;
		overflow: hidden;
	}

	/* Links inside the dropdown */
	.dropdown-content a {
		color: black;
		padding: 12px 16px;
		display: block;
		border: none;
	}

	.dropdown-content a:hover {
		background-color: #f1f1f1;
		color: var(--accent);
	}

	/* Show dropdown on hover */
	.dropdown:hover .dropdown-content {
		display: block;
	}

</style>
