---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category } = Astro.props;

// 1. Fetch related posts (Find posts with the same category, excluding the one currently being read)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
	.filter((post) => post.data.category === category && post.data.title !== title)
	.slice(0, 3); // Grab up to 3 posts

// 2. Generate sharing URL (Fallback to a placeholder if domain isn't set yet)
const siteUrl = Astro.site ? Astro.site.href : 'https://mytechblog.com';
const postUrl = `${siteUrl}${Astro.url.pathname}`;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main { width: 100%; max-width: 100%; margin: 0; padding-top: 2rem; }
			.hero-image { width: 100%; max-width: 1000px; margin: 0 auto; padding: 0 1rem; }
			.hero-image img { display: block; margin: 0 auto; border-radius: 16px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1); width: 100%; height: auto; }
			.prose { width: 100%; max-width: 720px; margin: auto; padding: 3rem 1rem; color: var(--text-main); font-size: 1.15rem; line-height: 1.8; }
			.title { margin-bottom: 2.5em; text-align: center; }
			.title h1 { margin: 0.2em 0 0.5em 0; font-size: 3rem; font-weight: 800; line-height: 1.2; letter-spacing: -0.02em; }
			.date { margin-bottom: 0.5em; color: var(--text-muted); font-size: 0.95rem; }
			.category-pill { display: inline-block; background-color: var(--accent); color: white; padding: 0.3rem 0.8rem; border-radius: 999px; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; margin-bottom: 1rem; }
			.divider { border: none; border-top: 1px solid var(--border-color); margin: 2rem 0; }
			
			/* --- NEW STYLES BELOW --- */
			
			/* Share Buttons */
			.share-section { display: flex; align-items: center; gap: 1rem; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border-color); }
			.share-text { font-weight: 600; color: var(--text-main); }
			.share-btn { padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 0.9rem; color: white; transition: opacity 0.2s; }
			.share-btn:hover { opacity: 0.8; }
			.btn-x { background: #000000; }
			.btn-linkedin { background: #0a66c2; }
			.btn-facebook { background: #1877f2; }

			/* Author Box */
			.author-box { display: flex; align-items: center; gap: 1.5rem; background: var(--bg-body); padding: 2rem; border-radius: 12px; margin-top: 3rem; border: 1px solid var(--border-color); }
			.author-avatar { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; }
			.author-info h3 { margin: 0 0 0.5rem 0; font-size: 1.3rem; }
			.author-info p { margin: 0; color: var(--text-muted); font-size: 1rem; line-height: 1.5; }

			/* Related Posts */
			.related-section { margin-top: 4rem; padding-top: 3rem; border-top: 2px solid var(--border-color); }
			.related-section h2 { margin-bottom: 1.5rem; }
			.related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; }
			.related-card { text-decoration: none; color: inherit; display: block; transition: transform 0.2s; }
			.related-card:hover { transform: translateY(-3px); }
			.related-card img { width: 100%; height: 140px; object-fit: cover; border-radius: 8px; margin-bottom: 0.8rem; border: 1px solid var(--border-color); }
			.related-card h4 { margin: 0 0 0.5rem 0; font-size: 1.1rem; line-height: 1.3; transition: color 0.2s; }
			.related-card:hover h4 { color: var(--accent); }
			.related-date { color: var(--text-muted); font-size: 0.85rem; }

			@media (max-width: 600px) {
				.author-box { flex-direction: column; text-align: center; }
				.share-section { flex-wrap: wrap; }
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img src={heroImage} alt={title} />}
				</div>
				
				<div class="prose">
					<div class="title">
						{category && <span class="category-pill">{category}</span>}
						<h1>{title}</h1>
						<div class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && <span class="last-updated-on">• Last updated <FormattedDate date={updatedDate} /></span>}
						</div>
						<hr class="divider" />
					</div>
					
					<!-- 📖 Main Blog Content -->
					<div class="blog-content">
						<slot />
					</div>

					<!-- 🚀 NEW: Social Share Buttons -->
					<div class="share-section">
						<span class="share-text">Share this article:</span>
						<a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(postUrl)}`} target="_blank" class="share-btn btn-x">𝕏 Post</a>
						<a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`} target="_blank" class="share-btn btn-linkedin">in Share</a>
						<a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(postUrl)}`} target="_blank" class="share-btn btn-facebook">f Share</a>
					</div>

					<!-- 👤 NEW: Author Bio Box -->
					<div class="author-box">
						<img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?q=80&w=250&auto=format&fit=crop" alt="Author Profile" class="author-avatar" />
						<div class="author-info">
							<h3>Written by [Your Name]</h3>
							<p>A passionate software engineer and tech enthusiast writing about web development, gadgets, and the future of coding. I build things with Astro and share my journey here.</p>
						</div>
					</div>

					<!-- 📚 NEW: Related Posts -->
					{relatedPosts.length > 0 && (
						<div class="related-section">
							<h2>Read Next</h2>
							<div class="related-grid">
								{relatedPosts.map((post) => (
									<a href={`/blog/${post.id}/`} class="related-card">
										{post.data.heroImage ? (
											<img src={post.data.heroImage} alt={post.data.title} />
										) : (
											<div style="height: 140px; background: #e2e8f0; border-radius: 8px; margin-bottom: 0.8rem;"></div>
										)}
										<h4>{post.data.title}</h4>
										<span class="related-date"><FormattedDate date={post.data.pubDate} /></span>
									</a>
								))}
							</div>
						</div>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>