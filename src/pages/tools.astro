---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Tools | ${SITE_TITLE}`} description="Automation and AI tools." />
		<style>
			.tools-hero { text-align: center; padding: 5rem 1rem; background: linear-gradient(135deg, #4f46e5 0%, #312e81 100%); color: white; border-radius: 12px; margin: 2rem auto; max-width: 1200px; }
			.tools-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; max-width: 1200px; margin: 4rem auto; padding: 0 1rem; }
			.tool-card { padding: 2rem; border: 1px solid #e2e8f0; border-radius: 16px; background: white; text-align: center; }
			.promo-btn { display: inline-block; background: #4f46e5; color: white; padding: 1rem 2rem; border-radius: 8px; text-decoration: none; font-weight: bold; margin-top: 1.5rem; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="tools-hero">
				<h1>Smartivate Pro</h1>
				<p style="font-size: 1.2rem; max-width: 700px; margin: 1rem auto;">Looking for faster and easier ways to get things done? We build tools designed to help you automate tasks and save time.</p>
				<a href="http://www.smartivatepro.com" class="promo-btn" style="background: white; color: #4f46e5;">Visit SmartivatePro.com</a>
			</section>

			<div class="tools-grid">
				<div class="tool-card">
					<h3>Automation Tools</h3>
					<p>Each tool is built based on real workflows explained on this blog.</p>
				</div>
				<div class="tool-card">
					<h3>AI-Powered Systems</h3>
					<p>Leverage the power of artificial intelligence to scale your productivity.</p>
				</div>
				<div class="tool-card">
					<h3>Lead Generation</h3>
					<p>Professional solutions designed to help you find and engage customers.</p>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>